{
  "productName": "Web2App",
  "version": "0.1.0",
  "identifier": "com.web2app.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173/",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Web2App",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:4173/"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
